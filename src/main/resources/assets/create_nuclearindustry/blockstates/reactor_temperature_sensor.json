{
  "multipart": [
    { "when": { "facing": "north" }, "apply": { "model": "create_nuclearindustry:block/reactor_temperature_sensor" } },
    { "when": { "facing": "east" }, "apply": { "model": "create_nuclearindustry:block/reactor_temperature_sensor", "y": 90 } },
    { "when": { "facing": "south" }, "apply": { "model": "create_nuclearindustry:block/reactor_temperature_sensor", "y": 180 } },
    { "when": { "facing": "west" }, "apply": { "model": "create_nuclearindustry:block/reactor_temperature_sensor", "y": 270 } },
    { "when": { "facing": "up" }, "apply": { "model": "create_nuclearindustry:block/reactor_temperature_sensor", "x": 270 } },
    { "when": { "facing": "down" }, "apply": { "model": "create_nuclearindustry:block/reactor_temperature_sensor", "x": 90 } }
  ]
}
